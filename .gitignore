# ==============================================================================
# DOCTOR APPOINTMENT SYSTEM — .gitignore
# ==============================================================================

# ------------------------------------------------------------------------------
# ENVIRONMENT & SECRETS
# ------------------------------------------------------------------------------
.env
*.env
!.env.example

# ------------------------------------------------------------------------------
# PYTHON
# ------------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/

# Virtual environments
venv/
.venv/
env/
.env/
ENV/

# Pytest
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# MyPy
.mypy_cache/
.dmypy.json
dmypy.json

# ------------------------------------------------------------------------------
# DJANGO
# ------------------------------------------------------------------------------
# Django collected static files (generated by `collectstatic`)
staticfiles/
*.log

# Django migrations (keep your migrations — comment this out if intentional)
# */migrations/*.py
# */migrations/*.pyc

# Local SQLite database (only used in development)
db.sqlite3

# Django media uploads (local dev only — production uses AWS S3)
/docappsystem/media/*
!/docappsystem/media/.gitkeep

# ------------------------------------------------------------------------------
# DOCKER & CI/CD
# ------------------------------------------------------------------------------
# WAF/Nginx log output directory (created at runtime)
waf-logs/

# OWASP ZAP security scan reports (generated by Jenkins pipeline)
zap-reports/

# ------------------------------------------------------------------------------
# IDEs & EDITORS
# ------------------------------------------------------------------------------
# JetBrains (PyCharm, IntelliJ)
.idea/
*.iml
*.iws
*.ipr

# VS Code
.vscode/
*.code-workspace

# Vim / Emacs
*.swp
*.swo
*~
\#*\#

# Sublime Text
*.sublime-project
*.sublime-workspace

# ------------------------------------------------------------------------------
# OPERATING SYSTEM
# ------------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db

# Windows
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# ------------------------------------------------------------------------------
# NODE / FRONTEND (if applicable)
# ------------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ------------------------------------------------------------------------------
# SONARQUBE
# ------------------------------------------------------------------------------
.sonar/
.scannerwork/
