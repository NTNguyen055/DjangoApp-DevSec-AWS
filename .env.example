# ==============================================================================
# DOCTOR APPOINTMENT SYSTEM — Environment Variables Example
# ==============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit the real .env file to version control.
# ------------------------------------------------------------------------------

# ------------------------------------------------------------------------------
# DJANGO CORE SETTINGS
# ------------------------------------------------------------------------------
# A long, random, secret string. Generate one at: https://djecrety.ir/
SECRET_KEY=your-django-secret-key-here

# Set to 0 (False) in production, 1 (True) only for local development
DEBUG=0

# Comma-separated list of allowed hosts (e.g., yourdomain.com,www.yourdomain.com)
ALLOWED_HOSTS=*

# ------------------------------------------------------------------------------
# AWS S3 — MEDIA FILE STORAGE
# Used to store user-uploaded files (profile pictures, media assets)
# ------------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
AWS_STORAGE_BUCKET_NAME=your-s3-bucket-name
AWS_S3_REGION_NAME=ap-southeast-1

# ------------------------------------------------------------------------------
# AWS RDS — MYSQL DATABASE (Primary / Write Node)
# ------------------------------------------------------------------------------
RDS_DB_NAME=your_database_name
RDS_USERNAME=your_db_username
RDS_PASSWORD=your_db_password
RDS_ENDPOINT=your-primary-rds-endpoint.rds.amazonaws.com
RDS_PORT=3306

# ------------------------------------------------------------------------------
# AWS RDS — MYSQL DATABASE (Read Replica / Read Node)
# Used for SELECT queries via Django's Primary-Replica DB Router
# ------------------------------------------------------------------------------
RDS_REPLICA_ENDPOINT=your-replica-rds-endpoint.rds.amazonaws.com

# ------------------------------------------------------------------------------
# DOCKER IMAGE TAGS (Used by docker-compose.yml at runtime)
# These are typically injected by the Jenkins CI/CD pipeline automatically
# ------------------------------------------------------------------------------
DOCKER_USER=your_dockerhub_username
IMAGE_NAME=doctor-appointment
TAG=latest
